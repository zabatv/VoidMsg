{
  "name": "messenger-mvp",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm run dev -w apps/server\" \"npm run dev -w apps/web\"",
    "dev:server": "npm run dev -w apps/server",
    "dev:web": "npm run dev -w apps/web",
    "db:generate": "npm run db:generate -w apps/server",
    "db:push": "npm run db:push -w apps/server",
    "db:migrate": "npm run db:migrate -w apps/server",
    "build": "npm run build -w apps/web",
    "start": "npm run start -w apps/server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}